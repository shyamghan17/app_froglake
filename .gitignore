# OS / Editor
.DS_Store
.idea/
.vscode/

# Local tooling
.trae/
/.phpunit.result.cache

# Environment
/.env
/.env.*
!/.env.example

# Dependencies
/vendor/
/node_modules/

# Frontend build artifacts
/public/hot
!/public/build/
!/public/build/**

# Laravel cache / runtime files
/bootstrap/cache/*.php
/storage/*.key
/storage/logs/*
!/storage/logs/.gitignore
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore

# Databases / dumps
/database/*.sqlite
/database/*.sqlite-*
/*.sql

# User uploads / symlinked public storage
/storage/app/public/*
!/storage/app/public/.gitignore
/public/storage

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local-only utility files
/phpinfo.php
