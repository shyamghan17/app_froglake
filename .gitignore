# OS / Editor
.DS_Store
.idea/
.vscode/

# Environment
/.env
/.env.*
!/.env.example

# Dependencies
/vendor/
/node_modules/

# Build artifacts
/public/build/
/public/hot

# Laravel cache / runtime files
/bootstrap/cache/*.php
/storage/*.key
/storage/logs/*
!/storage/logs/.gitignore
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore

# Databases / dumps
/database/*.sqlite
/database/*.sqlite-*
/*.sql

# Logs / tooling
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/.phpunit.result.cache
